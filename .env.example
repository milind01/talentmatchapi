# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/docai_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=docai_db

# Vector Database
VECTOR_DB_TYPE=pinecone  # pinecone, weaviate, qdrant
PINECONE_API_KEY=your_pinecone_key
PINECONE_ENVIRONMENT=your_environment
PINECONE_INDEX_NAME=docai-index
PINECONE_DIMENSION=1536

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# LLM Configuration (Ollama - Free, Local)
# Start Ollama: ollama serve
# Pull a model: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage
STORAGE_TYPE=local  # local, s3, azure
S3_BUCKET_NAME=docai-bucket
S3_REGION=us-east-1
AZURE_STORAGE_CONNECTION_STRING=

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Evaluation
EVALUATION_ENABLED=true
EVALUATION_METRICS=["bleu", "rouge", "similarity"]
